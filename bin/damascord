#!/usr/bin/env ruby
# frozen_string_literal: true

require 'bundler/setup'
require_relative '../lib/damascord'

begin
  Damascord::CLI.start(ARGV)
rescue Interrupt
  puts "\nPollux silenciado pelo mestre. Encerrando com dignidade."
  exit 0
rescue StandardError => e
  puts "\n[COLAPSO TOTAL MURPHYANO]: #{e.message}"
  exit 1
end
